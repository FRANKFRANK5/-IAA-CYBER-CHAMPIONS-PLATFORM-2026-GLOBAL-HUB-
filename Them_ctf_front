<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Matrix Neon Buttons - Zaidi ya HackTheBox
    document.querySelectorAll('.btn-primary, .btn-success, .btn-info').forEach(btn => {
        btn.style.boxShadow = "0 0 20px rgba(0, 255, 65, 0.4)";
        btn.style.border = "2px solid #00ff41";
        btn.style.background = "rgba(0, 255, 65, 0.05)";
        btn.style.color = "#00ff41";
        btn.style.textTransform = "uppercase";
        btn.style.fontWeight = "bold";
        btn.style.letterSpacing = "1px";
        btn.style.transition = "0.3s";
        
        btn.onmouseover = () => { 
            btn.style.background = "#00ff41"; 
            btn.style.color = "#000"; 
            btn.style.boxShadow = "0 0 40px #00ff41";
        };
        btn.onmouseout = () => { 
            btn.style.background = "rgba(0, 255, 65, 0.05)"; 
            btn.style.color = "#00ff41"; 
            btn.style.boxShadow = "0 0 20px rgba(0, 255, 65, 0.4)";
        };
    });

    // 2. Podium Logic - The Hall of Fame
    const tableRows = document.querySelectorAll('table tbody tr');
    if (tableRows.length >= 3) {
        const top3 = [
            { name: tableRows[0].cells[1].innerText.trim(), score: tableRows[0].cells[2].innerText.trim() },
            { name: tableRows[1].cells[1].innerText.trim(), score: tableRows[1].cells[2].innerText.trim() },
            { name: tableRows[2].cells[1].innerText.trim(), score: tableRows[2].cells[2].innerText.trim() }
        ];

        const podiumHTML = `
            <div class="podium-wrapper">
                <h2 class="arena-title">🏆 LEADERBOARD - THE ARENA 🛡️</h2>
                <div class="podium-container">
                    <div class="podium-card rank-2">
                        <div class="trophy-silver">🥈</div>
                        <div class="winner-frame">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${top3[1].name}" class="avatar">
                        </div>
                        <div class="winner-name">${top3[1].name}</div>
                        <div class="winner-tag">🥈 2nd PLACE</div>
                        <div class="winner-points">${top3[1].score} PTS</div>
                    </div>

                    <div class="podium-card rank-1">
                        <div class="trophy-gold">🏆</div>
                        <div class="winner-frame-gold">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${top3[0].name}" class="avatar-gold">
                        </div>
                        <div class="winner-name-gold">${top3[0].name}</div>
                        <div class="winner-tag-gold">👑 ULTIMATE CHAMPION</div>
                        <div class="winner-points-gold">${top3[0].score} PTS</div>
                    </div>

                    <div class="podium-card rank-3">
                        <div class="trophy-bronze">🥉</div>
                        <div class="winner-frame">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${top3[2].name}" class="avatar">
                        </div>
                        <div class="winner-name">${top3[2].name}</div>
                        <div class="winner-tag">🥉 3rd PLACE</div>
                        <div class="winner-points">${top3[2].score} PTS</div>
                    </div>
                </div>
            </div>
        `;

        const scoreboardHeader = document.querySelector('.container h1') || document.querySelector('.container .row:first-child');
        if(scoreboardHeader && !document.querySelector('.podium-wrapper')) {
             scoreboardHeader.style.display = 'none'; // Tunaficha header ya zamani
             scoreboardHeader.insertAdjacentHTML('afterend', podiumHTML);
        }
    }
});
</script>

